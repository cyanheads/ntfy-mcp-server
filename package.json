{
  "name": "ntfy-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for ntfy — send push notifications to devices via the ntfy.sh service.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ntfy-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "AGENTS.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "rebuild": "tsx scripts/clean.ts && tsx scripts/build.ts",
    "clean": "tsx scripts/clean.ts",
    "devcheck": "tsx scripts/devcheck.ts",
    "tree": "tsx scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "tsx scripts/lint-mcp.ts",
    "changelog:build": "tsx scripts/build-changelog.ts",
    "changelog:check": "tsx scripts/build-changelog.ts --check",
    "test": "vitest run",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": ["mcp", "mcp-server", "model-context-protocol"],
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.8.19",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.2",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
