# ── Transport ──────────────────────────────────────────────────────────
# MCP_TRANSPORT_TYPE=stdio          # stdio | http (default: stdio)
# MCP_HTTP_PORT=3010                # HTTP port (default: 3010)
# MCP_HTTP_HOST=127.0.0.1           # HTTP host (default: 127.0.0.1)
# MCP_HTTP_ENDPOINT_PATH=/mcp      # HTTP endpoint path (default: /mcp)
# MCP_HTTP_MAX_BODY_BYTES=1048576  # Max request body bytes; 413 over limit, 0 disables (default: 1048576)
# MCP_PUBLIC_URL=                  # Public origin behind a TLS-terminating proxy (e.g. https://mcp.example.com)

# ── Auth ──────────────────────────────────────────────────────────────
# MCP_AUTH_MODE=none                # none | jwt | oauth (default: none)
# MCP_AUTH_SECRET_KEY=              # JWT secret (required for jwt mode)

# ── Storage ───────────────────────────────────────────────────────────
# STORAGE_PROVIDER_TYPE=in-memory   # in-memory | filesystem | supabase | cloudflare-r2 | cloudflare-kv | cloudflare-d1

# ── Session ──────────────────────────────────────────────────────────
# MCP_SESSION_MODE=stateful         # stateful | stateless (default: stateful)

# ── Memory ───────────────────────────────────────────────────────────
# MCP_GC_PRESSURE_INTERVAL_MS=0     # Opt-in forced Bun.gc(true) interval, ms (Bun only). Drains old-gen backlog
                                    # under sustained HTTP load (issue #50). Try 60000 if RSS grows. Default: 0.

# ── Logging ───────────────────────────────────────────────────────────
# MCP_LOG_LEVEL=info                # debug | info | notice | warning | error

# ── Telemetry ─────────────────────────────────────────────────────────
# OTEL_ENABLED=false                          # Enable OpenTelemetry (default: false)
# OTEL_EXPORTER_OTLP_ENDPOINT=               # OTLP endpoint URL (e.g., http://localhost:4318)

# ── Server-specific (ntfy) ───────────────────────────────────────────
# Two configuration shapes — pick one. NTFY_SERVERS wins when both are set.
#
# (A) Multi-server registry — JSON array, first entry is the default base.
#     Auth is scoped per-entry; per-call `base_url` overrides that match a
#     registered base forward that entry's auth, anything else goes out
#     unauthenticated.
# NTFY_SERVERS=[{"baseUrl":"https://ntfy.sh"},{"baseUrl":"https://ntfy.example.com","authToken":"tk_..."}]
#
# (B) Single-server shorthand — used when NTFY_SERVERS is unset.
# NTFY_BASE_URL=https://ntfy.sh           # Base URL of the ntfy server, no trailing slash
# NTFY_AUTH_TOKEN=                        # Bearer access token (`tk_...`); mutually exclusive with NTFY_AUTH_USERNAME/PASSWORD
# NTFY_AUTH_USERNAME=                     # Basic auth username; required together with NTFY_AUTH_PASSWORD
# NTFY_AUTH_PASSWORD=                     # Basic auth password; required together with NTFY_AUTH_USERNAME
#
# Shared
# NTFY_DEFAULT_TOPIC=                     # Topic used when a tool call omits `topic`
# NTFY_REQUEST_TIMEOUT_MS=15000           # Per-request HTTP timeout (ms)
# NTFY_MAX_RETRIES=3                      # Max retry attempts for transient upstream failures (5xx, network, 429)
